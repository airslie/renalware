SECRET_KEY_BASE="123"

DEFAULT_FROM_EMAIL_ADDRESS=kch-tr.renal@nhs.net
PHONE_NUMBER_ON_LETTERS=020 3299 6233
RENAL_UNIT_ON_LETTERS=King's Renal Unit
DISPLAY_FEEDBACK_BANNER=1
RAILS_MAX_THREADS=1
# Un-commenting this line will cause mail to be sent to external parties eg GP Practices
# ALLOW_EXTERNAL_MAIL=1
FALLBACK_EMAIL_ADDRESS_FOR_TEST_MESSAGES=dev@airslie.com
LDAP_ADMIN_USER=admin

# Ensure LDAP is disabled for tests (even if it's enabled in .env)
LDAP_ENABLE=false
LDAP_HOST=ldap.example.com
LDAP_PORT=389
LDAP_BASE=dc=renalware,dc=app
LDAP_SSL=false
LDAP_ATTRIBUTE_MAPPINGS='{"email":"mail","given_name":"givenName","family_name":"sn","username":"uid"}'
LDAP_ADMIN_USER=admin
LDAP_ADMIN_PASSWORD=admin_password
LDAP_CLINICAL_GROUP=cn=renalware (clinical),ou=groups,dc=renalware,dc=app
LDAP_READONLY_GROUP=cn=renalware (readonly),ou=groups,dc=renalware,dc=app
LDAP_LOGGER=true
