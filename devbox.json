{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": {
    "postgresql_16": {
      "version": "16",
      "outputs": ["out", "dev"],
    },
    "libyaml": {
      "version": "latest",
      "outputs": ["dev"],
    },
    "pkg-config":     "latest",
    "gcc":            "latest",
    "gnumake":        "latest",
    "lsof":           "latest",
    "wkhtmltopdf":    "latest",
    "yarn":           "latest",
    "nodejs":         "22.11.0",
    "imagemagickBig": "latest",
    "vips": {
      "version": "latest",
      "outputs": ["dev", "bin", "out"],
    },
    "ghostscript": {
      "version": "latest",
      "outputs": ["fonts", "out"],
    },
    "pandoc":              "latest",
    "inotifytools":        "latest",
    "ruby":                "3.4",
    "playwright.browsers": "",
  },
  "env": {
    "SETUP_COMPLETE":           "$DEVBOX_PROJECT_ROOT/.devbox/.setup-complete",
    "PLAYWRIGHT_BROWSERS_PATH": "$DEVBOX_PACKAGES_DIR",
  },
  "shell": {
    "init_hook": [
      "if [ ! -f $SETUP_COMPLETE ]; then",
      "  echo 'Welcome to the Renalware codebase!'",
      "  echo 'To get started, run `devbox run setup`.'",
      "  echo 'This will install all the dependencies and create the database.'",
      "fi",
    ],
    "scripts": {
      "test": [ "rails test", ],
      "setup": [
        "[ -f \"$SETUP_COMPLETE\" ] && echo Nothing to do, run: 'devbox run reset' to re-initialize the project && exit 0",
        "echo ''",
        "echo '>>>> Initializing database'",
        "initdb",
        "echo \"CREATE ROLE renalware WITH LOGIN PASSWORD 'renalware' SUPERUSER;\" | postgres --single postgres",
        "git submodule update --init --recursive",
        "echo ''",
        "echo '>>>> Installing Gems'",
        "bundle check || bundle",
        "echo ''",
        "echo '>>>> Installing Node packages'",
        "yarn",
        "echo ''",
        "echo '>>>> Starting PostgreSQL'",
        "devbox services start postgresql",
        "bin/wait-for-port 5432 30",
        "echo '>>>> Seeding database'",
        "rails db:setup",
        "overcommit --force",
        "touch $SETUP_COMPLETE",
        "devbox services down",
        "echo ''",
        "echo '>>>> Setup complete!'",
        "echo 'Now run `devbox services up` to start process-compose'",
      ],
      "update": [
        "bundle check || bundle",
        "rails db:migrate",
        "rails db:migrate RAILS_ENV=test",
      ],
      "purge": [
        "devbox services down >/dev/null 2>&1 || true",
        "rm -rf .devbox && devbox install",
      ],
      "reset": [
        "devbox run purge",
        "devbox run setup",
      ],
    },
  },
}
