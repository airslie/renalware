.flex.flex-col.gap-2
  = f.label :username, "Username", class: "text-md font-semibold text-slate-600"
  = f.text_field :username,
                  autofocus: true,
                  autocomplete: "username",
                  required: true,
                  class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-base text-slate-900 shadow-sm transition focus:border-sky-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-sky-100"
